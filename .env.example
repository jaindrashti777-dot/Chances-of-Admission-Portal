# ==============================================================================
# Admission Prediction API - Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend (FastAPI / Render)
# ------------------------------------------------------------------------------

# Cloud providers like Render set PORT automatically.
# PORT=8000

# Comma-separated list of allowed browser origins.
# CORS_ORIGINS=http://localhost:3000,https://chances-of-admission-portal.vercel.app

# ------------------------------------------------------------------------------
# Frontend (Next.js / Vercel)
# ------------------------------------------------------------------------------

# Public URL of the FastAPI backend.
# NEXT_PUBLIC_API_URL=http://localhost:8000
